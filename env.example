# ── Azure OpenAI — Grup 1 (Sweden) ───────────────────────────────────────────
AZURE_API_KEY_1=your_azure_api_key_1
AZURE_API_BASE_1=https://your-resource-1.cognitiveservices.azure.com/

# ── Azure OpenAI — Grup 2 (West Germany) ─────────────────────────────────────
AZURE_API_KEY_2=your_azure_api_key_2
AZURE_API_BASE_2=https://your-resource-2.cognitiveservices.azure.com/

# ── Azure API Version ─────────────────────────────────────────────────────────
AZURE_API_VERSION=2025-04-01-preview

# ── LiteLLM ───────────────────────────────────────────────────────────────────
LITELLM_MASTER_KEY=your_litellm_master_key

# ── FastAPI JWT ───────────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_min_32_chars

# ── Canary Deployment (0.0 → 1.0) ────────────────────────────────────────────
# 0.0 = herkes SERBEST (shadow mode)
# 0.5 = %50 aktif_mod, %50 SERBEST
# 1.0 = herkes aktif_mod
CANARY_RATE=0.0

# ── Aktif Mod: SERBEST | KONTROLLU | ZORUNLU ─────────────────────────────────
AKTIF_MOD=ZORUNLU

# ── Whitelist (virgülle ayır) ─────────────────────────────────────────────────
WHITELIST=ceo@firma.com,hukuk@firma.com
